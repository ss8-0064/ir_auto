package com.irs.signals.util;

import com.irs.signals.Config;
import net.minecraft.resources.ResourceLocation;
import net.minecraft.world.entity.Entity;
import net.minecraftforge.registries.ForgeRegistries;

import java.util.Locale;

/**
 * 通用列车（滚动车辆）检测器。
 *
 * 由于沉浸铁路（Immersive Railroading）的 maven 仓库在编译期不可达，本模组不直接引用其类，
 * 而是通过实体类型 ID 与类名的关键词匹配来识别列车实体。这种做法跨 IR 版本兼容，
 * 默认关键词涵盖 rolling / locomotive / train，可在配置中自定义。
 */
public final class TrainDetector {
    private TrainDetector() {}

    public static boolean isTrain(Entity entity) {
        if (entity == null) return false;

        // 1) 实体类型 ID 匹配（如 immersiverailroading:rolling_stock_...）
        ResourceLocation key = ForgeRegistries.ENTITY_TYPES.getKey(entity.getType());
        String typeId = key == null ? "" : (key.getNamespace() + ":" + key.getPath()).toLowerCase(Locale.ROOT);

        // 2) 类名匹配（如 cam72sec.immersiverailroading.entity.EntityRollingStock）
        String className = entity.getClass().getName().toLowerCase(Locale.ROOT);

        for (String raw : Config.keywords()) {
            String kw = raw.toLowerCase(Locale.ROOT);
            if (!kw.isEmpty() && (typeId.contains(kw) || className.contains(kw))) {
                return true;
            }
        }
        return false;
    }
}
